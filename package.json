{
    "name": "screener-tracker-ui",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite --host",
        "build": "vite build",
        "preview": "vite preview",
        "cf:dev": "wrangler dev",
        "cf:deploy": "npm run build && wrangler deploy",
        "mobile:start": "npm --prefix \"./android-app\" run start",
        "mobile:android": "npm --prefix \"./android-app\" run android",
        "mobile:ios": "npm --prefix \"./android-app\" run ios",
        "mobile:web": "npm --prefix \"./android-app\" run web",
        "mobile:build:android:apk": "npm --prefix \"./android-app\" run build:android:apk",
        "mobile:build:android:aab": "npm --prefix \"./android-app\" run build:android:aab",
        "mobile:build:ios:ipa": "npm --prefix \"./android-app\" run build:ios:ipa"
    },
    "dependencies": {
        "clsx": "^2.1.0",
        "framer-motion": "^11.0.3",
        "lucide-react": "^0.575.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-virtuoso": "^4.18.1",
        "tailwind-merge": "^2.2.1"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.2.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "javascript-obfuscator": "^5.3.0",
        "rollup-plugin-obfuscator": "^1.1.0",
        "tailwindcss": "^4.2.1",
        "vite": "^8.0.0-beta.15",
        "wrangler": "^4.5.0"
    }
}
