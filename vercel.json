{
    "regions": [
        "bom1"
    ],
    "headers": [
        {
            "source": "/data.json",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, s-maxage=54000, stale-while-revalidate=60"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}