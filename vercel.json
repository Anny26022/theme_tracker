{
    "regions": [
        "bom1"
    ],
    "headers": [
        {
            "source": "/data.json",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, s-maxage=54000, stale-while-revalidate=60"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/api/v1/fuckyouuuu",
            "destination": "/api/fuckyouuuu"
        },
        {
            "source": "/api/v1/fckyouuu1",
            "destination": "/api/fckyouuu1"
        },
        {
            "source": "/api/v1/fckyouuu2",
            "destination": "/api/scanx"
        },
        {
            "source": "/api/mobile-batch",
            "destination": "/api/mobile-batch"
        },
        {
            "source": "/api/mobile-strike",
            "destination": "/api/mobile-strike"
        },
        {
            "source": "/api/mobile-scanx",
            "destination": "/api/mobile-scanx"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
